{
  "name": "stutter",
  "version": "2.4.1",
  "description": "RSVP for browsers",
  "main": "index.js",
  "repository": "https://github.com/jamestomasino/stutter",
  "author": "James Tomasino <james@tomasino.org>",
  "license": "GPL-3.0",
  "private": false,
  "scripts": {
    "test": "node --test",
    "manifest:chrome": "node scripts/build-manifest.cjs chrome",
    "manifest:firefox": "node scripts/build-manifest.cjs firefox",
    "manifest:edge": "node scripts/build-manifest.cjs edge",
    "build:chrome": "npm run manifest:chrome && npm run build",
    "build:firefox": "npm run manifest:firefox && npm run build",
    "build:edge": "npm run manifest:edge && npm run build",
    "extension": "npm run extension:firefox",
    "extension:firefox": "npm run build:firefox && web-ext run --verbose",
    "extension:chromium": "npm run build:chrome && web-ext run --target chromium --chromium-binary chromium --verbose",
    "package:chrome": "npm run build:chrome && web-ext build --overwrite-dest --filename \"stutter-chrome-$npm_package_version.zip\"",
    "package:firefox": "npm run build:firefox && web-ext build --overwrite-dest --filename \"stutter-firefox-$npm_package_version.zip\"",
    "package:edge": "npm run build:edge && web-ext build --overwrite-dest --filename \"stutter-edge-$npm_package_version.zip\"",
    "package:src": "git archive --format zip --output \"./web-ext-artifacts/$(basename \"$(pwd)\")-$npm_package_version-src.zip\" HEAD",
    "package:all": "npm run package:chrome && npm run package:firefox && npm run package:edge && npm run package:src",
    "package": "npm run package:all",
    "release:prepare:patch": "node scripts/release-prepare.cjs patch",
    "release:prepare:minor": "node scripts/release-prepare.cjs minor",
    "release:prepare:major": "node scripts/release-prepare.cjs major",
    "release:tag": "node scripts/release-tag.cjs",
    "release:tag:push": "node scripts/release-tag.cjs --push",
    "build": "webpack --config 'webpack.bg.js' && webpack --config 'webpack.content.js' && webpack --config 'webpack.options.js'",
    "webext-test": "npm run manifest:firefox && node scripts/webext-lint.cjs"
  },
  "browserslist": "> 0.25%, not dead",
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/plugin-transform-runtime": "^7.26.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/runtime": "^7.26.9",
    "@babel/runtime-corejs3": "^7.26.9",
    "babel-loader": "^9.2.1",
    "core-js": "3",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "sass": "^1.85.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "web-ext": "^8.4.0",
    "webextension-polyfill": "^0.12.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "hyphen": "^1.10.6"
  }
}
